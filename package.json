{
  "name": "cypher-of-healing-api",
  "version": "0.1.0",
  "private": true,
  "description": "CypherOfHealing.com — Personal brand platform: booking, store, academy, webinars, consultations",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.41.1",
    "@hono/zod-validator": "^0.5.0",
    "@neondatabase/serverless": "^0.10.0",
    "@sentry/cloudflare": "^10.53.1",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.7.0",
    "jose": "^6.0.0",
    "nanoid": "^5.0.0",
    "postgres": "^3.4.0",
    "stripe": "^17.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.0",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.0.0"
  }
}
